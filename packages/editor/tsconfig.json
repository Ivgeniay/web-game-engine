{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noUncheckedSideEffectImports": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@proton/ui": ["../ui/src/index.ts"],
      "@proton/engine": ["../engine/src/index.ts"],
      "@proton/shared": ["../shared/src/index.ts"],
      "@proton/stdlib": ["../stdlib/src/index.ts"]
    }
  },
  "include": [
    "src",
    "../ui/src",
    "../engine/src",
    "../shared/src",
    "../stdlib/src"
  ]
}

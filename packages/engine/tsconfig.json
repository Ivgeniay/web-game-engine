{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["@webgpu/types", "node"],
    "lib": ["ESNext", "DOM"],
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src", "tests"]
}

